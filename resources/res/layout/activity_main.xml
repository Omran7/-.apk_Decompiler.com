<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:fitsSystemWindows="true" android:layout_width="match_parent" android:layout_height="match_parent">
    <FrameLayout android:id="@+id/activity_city_structure_frame_layout" android:layout_width="match_parent" android:layout_height="match_parent"/>
    <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/line_top" android:layout_width="match_parent" android:layout_height="0dp" app:layout_constraintGuide_percent="0.25"/>
    <LinearLayout android:orientation="vertical" android:id="@+id/activity_main_left_layout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/line_top">
        <RelativeLayout android:id="@+id/activity_main_buy_gold_button" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <RelativeLayout android:id="@+id/activity_main_gold_button" style="@style/circle_button_layout">
                <ImageView android:src="@drawable/button_circle_gold" style="@style/circle_button_image_view"/>
                <TextView android:text="@string/gift_first_buy_gold_title" style="@style/circle_button_text_view"/>
            </RelativeLayout>
            <ProgressBar android:layout_width="86dp" android:layout_height="86dp" android:layout_marginTop="-2dp" android:indeterminate="true" android:indeterminateDrawable="@drawable/button_light_double" android:layout_marginStart="-12dp"/>
        </RelativeLayout>
        <RelativeLayout android:id="@+id/activity_main_monthly_points_race_button" android:visibility="gone" style="@style/circle_button_layout">
            <ImageView android:src="@drawable/button_circle_points_race" style="@style/circle_button_image_view"/>
            <TextView android:id="@+id/activity_main_monthly_points_race_text" style="@style/circle_button_text_view"/>
            <ProgressBar android:layout_width="match_parent" android:layout_height="match_parent" android:indeterminate="true" android:indeterminateDrawable="@drawable/button_light_single" android:layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout android:id="@+id/activity_main_street_war_button" android:visibility="gone" style="@style/circle_button_layout">
            <ImageView android:src="@drawable/button_circle_street_war" style="@style/circle_button_image_view"/>
            <TextView android:text="@string/street_war_order" style="@style/circle_button_text_view"/>
        </RelativeLayout>
        <RelativeLayout android:id="@+id/activity_main_programming_helping_button" android:visibility="gone" style="@style/circle_button_layout">
            <ImageView android:src="@drawable/button_programming_helping" style="@style/circle_button_image_view"/>
            <TextView android:text="help me" style="@style/circle_button_text_view"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="-30dp" app:layout_constraintEnd_toStartOf="@+id/activity_main_right_layout" app:layout_constraintTop_toTopOf="@+id/activity_main_right_layout">
        <com.mtma.criminal.city.views.GameGridView android:id="@+id/activity_main_herbs_grid_view" android:visibility="gone" android:scrollbars="none" android:layout_width="wrap_content" android:layout_height="wrap_content" android:horizontalSpacing="2dp" android:stretchMode="none" android:columnWidth="46dp" android:divider="@android:color/transparent" android:overScrollMode="never" android:paddingStart="0dp" android:paddingEnd="30dp"/>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:id="@+id/activity_main_right_layout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="-46dp" android:layout_marginEnd="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toBottomOf="@+id/line_top">
        <RelativeLayout android:id="@+id/activity_main_herbs_button" android:visibility="invisible" android:layout_height="wrap_content" android:layout_marginTop="0dp" style="@style/circle_button_layout">
            <ImageView android:paddingLeft="10dp" android:paddingRight="10dp" android:src="@drawable/herbs_circle_icon" android:paddingHorizontal="10dp" style="@style/circle_button_image_view"/>
        </RelativeLayout>
        <RelativeLayout android:id="@+id/activity_main_phone_button" style="@style/circle_button_layout">
            <ImageView android:src="@drawable/button_circle_phone" style="@style/circle_button_image_view"/>
            <ImageView android:id="@+id/activity_main_phone_alert" android:padding="0dp" style="@style/bottom_bar_alert_icon_imageview"/>
            <TextView android:text="@string/phone" style="@style/circle_button_text_view"/>
        </RelativeLayout>
        <RelativeLayout android:id="@+id/activity_main_instructions_button" android:visibility="gone" style="@style/circle_button_layout">
            <ImageView android:src="@drawable/button_circle_instruction" style="@style/circle_button_image_view"/>
            <TextView android:text="@string/instructions" style="@style/circle_button_text_view"/>
        </RelativeLayout>
        <RelativeLayout android:id="@+id/activity_main_prizes_button" style="@style/circle_button_layout">
            <ImageView android:src="@drawable/button_circle_prizes" style="@style/circle_button_image_view"/>
            <ImageView android:id="@+id/activity_main_prizes_alert" android:padding="0dp" style="@style/bottom_bar_alert_icon_imageview"/>
            <TextView android:text="@string/prizes" style="@style/circle_button_text_view"/>
        </RelativeLayout>
        <RelativeLayout android:id="@+id/activity_main_monthly_card_button" android:visibility="gone" style="@style/circle_button_layout">
            <ImageView android:src="@drawable/button_circle_monthly_card" style="@style/circle_button_image_view"/>
            <TextView android:text="@string/monthly_card" style="@style/circle_button_text_view"/>
            <ProgressBar android:layout_width="match_parent" android:layout_height="match_parent" android:indeterminate="true" android:indeterminateDrawable="@drawable/button_light_single" android:layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout android:id="@+id/activity_main_activities_button" style="@style/circle_button_layout">
            <ImageView android:src="@drawable/button_circle_activities" style="@style/circle_button_image_view"/>
            <TextView android:text="@string/activities" style="@style/circle_button_text_view"/>
        </RelativeLayout>
    </LinearLayout>
    <FrameLayout android:id="@+id/activity_main_top_bar_frame_layout" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintTop_toTopOf="0"/>
    <FrameLayout android:id="@+id/activity_main_bottom_bar_frame_layout" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="0"/>
    <FrameLayout android:id="@+id/activity_main_body_frame_layout" android:layout_width="match_parent" android:layout_height="0dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintTop_toBottomOf="@+id/activity_main_top_bar_frame_layout"/>
    <FrameLayout android:id="@+id/activity_main_full_frame_layout" android:layout_width="match_parent" android:layout_height="match_parent"/>
    <LinearLayout android:gravity="center" android:id="@+id/activity_main_progress_bar_layout" android:background="@color/progress_bar_background" android:focusable="true" android:visibility="gone" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent">
        <ProgressBar android:layout_width="70dp" android:layout_height="70dp" android:indeterminate="true" android:indeterminateDrawable="@drawable/progress_bar_bullet"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
