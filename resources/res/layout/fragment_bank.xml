<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/background" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent">
    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <TextView android:id="@+id/fragment_bank_title" android:text="@string/bank" style="@style/fragment_default_title"/>
        <LinearLayout android:orientation="vertical" android:padding="12dp" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_above="@+id/fragment_bank_bottom_bar" android:layout_below="@+id/fragment_bank_title">
            <RelativeLayout android:background="@drawable/item_basic_background" android:paddingLeft="12dp" android:paddingTop="8dp" android:paddingRight="12dp" android:paddingBottom="8dp" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="120dp" android:paddingHorizontal="12dp" android:paddingVertical="8dp">
                <RelativeLayout android:id="@+id/fragment_bank_deposit_button" android:focusable="true" android:clickable="true" android:layout_width="90dp" android:layout_height="wrap_content" android:layout_centerVertical="true">
                    <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/button_blue" android:adjustViewBounds="true" android:layout_centerInParent="true"/>
                    <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/deposit" android:layout_centerInParent="true" style="@style/shadow_textview"/>
                </RelativeLayout>
                <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/fragment_bank_deposit_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_toEndOf="@+id/fragment_bank_deposit_button">
                    <LinearLayout android:gravity="end" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/fragment_bank_deposit_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/zero" android:layout_marginEnd="16dp" style="@style/shadow_textview"/>
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/deposit_value" style="@style/shadow_textview"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
            <LinearLayout android:gravity="end" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:layout_marginBottom="24dp" android:layout_marginEnd="8dp">
                <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/work_red_text" android:id="@+id/fragment_bank_deposit_tax" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" style="@style/shadow_textview"/>
                <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/tax_for_bank" style="@style/shadow_textview"/>
            </LinearLayout>
            <RelativeLayout android:background="@drawable/item_basic_background" android:paddingLeft="12dp" android:paddingTop="8dp" android:paddingRight="12dp" android:paddingBottom="8dp" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="120dp" android:paddingHorizontal="12dp" android:paddingVertical="8dp">
                <RelativeLayout android:id="@+id/fragment_bank_withdrawal_button" android:focusable="true" android:clickable="true" android:layout_width="90dp" android:layout_height="wrap_content" android:layout_centerVertical="true">
                    <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/button_blue" android:adjustViewBounds="true" android:layout_centerInParent="true"/>
                    <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:paddingBottom="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/withdrawal" android:layout_centerInParent="true" style="@style/shadow_textview"/>
                </RelativeLayout>
                <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/fragment_bank_withdrawal_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_toEndOf="@+id/fragment_bank_withdrawal_button">
                    <LinearLayout android:gravity="end" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/fragment_bank_withdrawal_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/zero" android:layout_marginEnd="16dp" style="@style/shadow_textview"/>
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/withdrawal_value" style="@style/shadow_textview"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
            <RelativeLayout android:background="@drawable/item_basic_background" android:padding="8dp" android:focusable="false" android:clickable="false" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp">
                <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/fragment_bank_deposit_container2" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:paddingBottom="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/balance_statement" style="@style/shadow_textview"/>
                    <LinearLayout android:gravity="right|center_vertical|center_horizontal|center|end" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="left|center_vertical|center_horizontal|center" android:layout_width="0dp" android:layout_height="wrap_content" android:text="@string/outside_bank" android:layout_weight="1" android:layout_marginStart="12dp" style="@style/shadow_textview"/>
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/fragment_bank_cash_outside_bank" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/deposit_value" style="@style/shadow_textview"/>
                        <ImageView android:layout_width="wrap_content" android:layout_height="24dp" android:layout_marginLeft="12dp" android:layout_marginRight="12dp" android:src="@drawable/cash_icon" android:adjustViewBounds="true" android:layout_marginHorizontal="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:gravity="right|center_vertical|center_horizontal|center|end" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="left|center_vertical|center_horizontal|center" android:layout_width="0dp" android:layout_height="wrap_content" android:text="@string/inside_bank" android:layout_weight="1" android:layout_marginStart="12dp" style="@style/shadow_textview"/>
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/fragment_bank_cash_inside_bank" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/deposit_value" style="@style/shadow_textview"/>
                        <ImageView android:layout_width="wrap_content" android:layout_height="24dp" android:layout_marginLeft="12dp" android:layout_marginRight="12dp" android:src="@drawable/cash_icon" android:adjustViewBounds="true" android:layout_marginHorizontal="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:gravity="right|center_vertical|center_horizontal|center|end" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/fragment_bank_gold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/deposit_value" style="@style/shadow_textview"/>
                        <ImageView android:layout_width="wrap_content" android:layout_height="20dp" android:layout_marginLeft="12dp" android:layout_marginRight="12dp" android:src="@drawable/gold_icon" android:adjustViewBounds="true" android:layout_marginHorizontal="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:gravity="right|center_vertical|center_horizontal|center|end" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/fragment_bank_check" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/deposit_value" style="@style/shadow_textview"/>
                        <ImageView android:layout_width="wrap_content" android:layout_height="24dp" android:layout_marginLeft="12dp" android:layout_marginRight="12dp" android:src="@drawable/check_icon" android:adjustViewBounds="true" android:layout_marginHorizontal="12dp"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/fragment_bank_bottom_bar" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_alignParentBottom="true">
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/bottom_bar_background" android:scaleType="fitXY" android:adjustViewBounds="true" app:layout_constraintTop_toTopOf="0"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/top_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.12"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/bottom_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.9"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/left_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.056"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/right_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.945"/>
            <LinearLayout app:layout_constraintBottom_toBottomOf="@+id/bottom_line" app:layout_constraintEnd_toEndOf="@+id/right_line" app:layout_constraintStart_toEndOf="@+id/left_line" app:layout_constraintTop_toBottomOf="@+id/top_line" style="@style/fragment_default_main_bottom_bar_layout">
                <RelativeLayout android:id="@+id/fragment_bank_back_button" style="@style/bottom_bar_layout">
                    <ImageView android:src="@drawable/button_back" style="@style/bottom_bar_imageview"/>
                    <TextView android:text="@string/button_back" style="@style/bottom_bar_textview"/>
                </RelativeLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="4"/>
                <RelativeLayout android:id="@+id/fragment_bank_loan_button" style="@style/bottom_bar_layout">
                    <ImageView android:src="@drawable/button_loan" style="@style/bottom_bar_imageview"/>
                    <TextView android:text="@string/button_loan" style="@style/bottom_bar_textview"/>
                </RelativeLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </RelativeLayout>
</FrameLayout>
