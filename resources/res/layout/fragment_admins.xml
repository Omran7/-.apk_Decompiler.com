<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/background" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <TextView android:id="@+id/fragment_admins_title" android:layout_width="match_parent" android:text="@string/settings_admins_name" app:layout_constraintTop_toTopOf="0" style="@style/fragment_default_title"/>
        <ListView android:id="@+id/fragment_admins_list_view" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginBottom="0dp" app:layout_constraintBottom_toTopOf="@+id/fragment_admins_bottom_line" app:layout_constraintTop_toBottomOf="@+id/fragment_admins_title" style="@style/fragment_default_list_view"/>
        <TextView android:id="@+id/fragment_admins_empty_view" app:layout_constraintBottom_toBottomOf="@+id/fragment_admins_list_view" app:layout_constraintEnd_toEndOf="@+id/fragment_admins_list_view" app:layout_constraintStart_toStartOf="@+id/fragment_admins_list_view" app:layout_constraintTop_toTopOf="@+id/fragment_admins_list_view" style="@style/fragment_default_empty_view"/>
        <ImageView android:id="@+id/fragment_admins_bottom_line" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:layout_marginRight="8dp" android:layout_marginBottom="8dp" android:src="@drawable/line_divider" android:adjustViewBounds="true" android:layout_marginHorizontal="8dp" app:layout_constraintBottom_toTopOf="@+id/fragment_admins_request_button"/>
        <RelativeLayout android:id="@+id/fragment_admins_request_button" android:focusable="true" android:clickable="true" android:layout_width="wrap_content" android:layout_height="56dp" android:layout_marginBottom="8dp" app:layout_constraintBottom_toTopOf="@+id/fragment_admins_bottom_bar" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0">
            <ImageView android:id="@+id/fragment_admins_request_button_image" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/button_blue_large" android:adjustViewBounds="true" android:layout_centerInParent="true"/>
            <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/button_admin_request" android:layout_centerInParent="true" style="@style/shadow_textview"/>
        </RelativeLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/fragment_admins_bottom_bar" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="0">
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/bottom_bar_background" android:scaleType="fitXY" android:adjustViewBounds="true" app:layout_constraintTop_toTopOf="0"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/top_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.12"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/bottom_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.9"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/left_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.056"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/right_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.945"/>
            <LinearLayout app:layout_constraintBottom_toBottomOf="@+id/bottom_line" app:layout_constraintEnd_toEndOf="@+id/right_line" app:layout_constraintStart_toEndOf="@+id/left_line" app:layout_constraintTop_toBottomOf="@+id/top_line" style="@style/fragment_default_main_bottom_bar_layout">
                <RelativeLayout android:id="@+id/fragment_admins_back_button" style="@style/bottom_bar_layout">
                    <ImageView android:src="@drawable/button_back" style="@style/bottom_bar_imageview"/>
                    <TextView android:text="@string/button_back" style="@style/bottom_bar_textview"/>
                </RelativeLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="4"/>
                <RelativeLayout android:id="@+id/fragment_admins_help_button" style="@style/bottom_bar_layout">
                    <ImageView android:src="@drawable/button_help" style="@style/bottom_bar_imageview"/>
                    <TextView android:text="@string/button_terms" style="@style/bottom_bar_textview"/>
                </RelativeLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
