<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/background" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent">
    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_above="@+id/fragment_first_buy_gold_bottom_bar" android:layout_alignParentTop="true">
            <ImageView android:id="@+id/fragment_first_buy_gold_background_top" android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/gift_first_buy_gold_background_top" android:adjustViewBounds="true" app:layout_constraintTop_toTopOf="0"/>
            <ImageView android:id="@+id/fragment_first_buy_gold_title_image" android:layout_width="0dp" android:layout_height="0dp" android:src="@drawable/gift_first_buy_gold_box" android:scaleType="fitXY" app:layout_constraintBottom_toBottomOf="@+id/fragment_first_buy_gold_title" app:layout_constraintEnd_toEndOf="@+id/fragment_first_buy_gold_title" app:layout_constraintStart_toStartOf="@+id/fragment_first_buy_gold_title" app:layout_constraintTop_toTopOf="@+id/fragment_first_buy_gold_title"/>
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:gravity="center" android:id="@+id/fragment_first_buy_gold_title" android:padding="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" style="@style/shadow_textview_small"/>
            <ImageView android:id="@+id/fragment_first_buy_gold_description_image" android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/gift_first_buy_gold_description" android:adjustViewBounds="true" app:layout_constraintTop_toBottomOf="@+id/fragment_first_buy_gold_background_top"/>
            <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:gravity="center" android:id="@+id/fragment_first_buy_gold_description" android:layout_width="wrap_content" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="@+id/fragment_first_buy_gold_description_image" app:layout_constraintEnd_toEndOf="@+id/fragment_first_buy_gold_description_image" app:layout_constraintStart_toStartOf="@+id/fragment_first_buy_gold_description_image" app:layout_constraintTop_toTopOf="@+id/fragment_first_buy_gold_description_image" style="@style/shadow_textview_small"/>
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/gift_first_buy_gold_background_bottom" android:adjustViewBounds="true" app:layout_constraintBottom_toBottomOf="0"/>
            <ListView android:id="@+id/fragment_first_buy_gold_list_view" android:padding="0dp" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginLeft="16dp" android:layout_marginRight="16dp" android:layout_marginBottom="20dp" android:listSelector="@android:color/transparent" android:layout_marginHorizontal="16dp" app:layout_constraintBottom_toTopOf="@+id/fragment_first_buy_gold_buy_button" app:layout_constraintTop_toBottomOf="@+id/fragment_first_buy_gold_description_image" style="@style/fragment_default_list_view"/>
            <RelativeLayout android:id="@+id/fragment_first_buy_gold_buy_button" android:focusable="true" android:clickable="true" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginBottom="20dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0">
                <ImageView android:id="@+id/fragment_upgrade_lab_upgrade_button_image_view" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/button_blue_large" android:adjustViewBounds="true" android:layout_centerInParent="true"/>
                <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/button_buy" android:layout_centerInParent="true" style="@style/shadow_textview"/>
            </RelativeLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/fragment_first_buy_gold_bottom_bar" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_alignParentBottom="true">
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/bottom_bar_background" android:scaleType="fitXY" android:adjustViewBounds="true" app:layout_constraintTop_toTopOf="0"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/top_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.12"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/bottom_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.9"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/left_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.056"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/right_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.945"/>
            <LinearLayout app:layout_constraintBottom_toBottomOf="@+id/bottom_line" app:layout_constraintEnd_toEndOf="@+id/right_line" app:layout_constraintStart_toEndOf="@+id/left_line" app:layout_constraintTop_toBottomOf="@+id/top_line" style="@style/fragment_default_main_bottom_bar_layout">
                <RelativeLayout android:id="@+id/fragment_first_buy_gold_back_button" style="@style/bottom_bar_layout">
                    <ImageView android:src="@drawable/button_back" style="@style/bottom_bar_imageview"/>
                    <TextView android:text="@string/button_back" style="@style/bottom_bar_textview"/>
                </RelativeLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </RelativeLayout>
</FrameLayout>
