<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/background" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <TextView android:id="@+id/fragment_black_market_title" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" style="@style/fragment_default_title"/>
        <RelativeLayout android:id="@+id/fragment_black_market_convert_button" android:focusable="true" android:clickable="true" android:layout_width="90dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" app:layout_constraintBottom_toBottomOf="@+id/fragment_black_market_image" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="@+id/fragment_black_market_image">
            <ImageView android:id="@+id/fragment_black_market_convert_button_image" android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/button_gray" android:adjustViewBounds="true" android:layout_centerInParent="true"/>
            <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/button_convert" android:layout_centerInParent="true" style="@style/shadow_textview"/>
        </RelativeLayout>
        <TextView android:id="@+id/fragment_black_market_edit_text" android:layout_width="0dp" android:layout_marginLeft="12dp" android:layout_marginRight="12dp" android:text="@string/zero" android:layout_marginHorizontal="12dp" app:layout_constraintBottom_toTopOf="@+id/fragment_black_market_seekbar_view" app:layout_constraintEnd_toEndOf="@+id/fragment_black_market_seekbar_view" app:layout_constraintStart_toStartOf="@+id/fragment_black_market_seekbar_view" app:layout_constraintTop_toTopOf="@+id/fragment_black_market_image" style="@style/seekbar_edit_text"/>
        <TextView android:id="@+id/fragment_black_market_minimum" android:layout_marginStart="4dp" app:layout_constraintBottom_toBottomOf="@+id/fragment_black_market_seekbar_view" app:layout_constraintStart_toEndOf="@+id/fragment_black_market_convert_button" app:layout_constraintTop_toTopOf="@+id/fragment_black_market_seekbar_view" style="@style/seekbar_minimum_text_view"/>
        <SeekBar android:id="@+id/fragment_black_market_seekbar_view" android:layout_width="0dp" android:layout_marginTop="8dp" app:layout_constraintBottom_toBottomOf="@+id/fragment_black_market_image" app:layout_constraintEnd_toStartOf="@+id/fragment_black_market_maximum" app:layout_constraintStart_toEndOf="@+id/fragment_black_market_minimum" app:layout_constraintTop_toBottomOf="@+id/fragment_black_market_edit_text" style="@style/seekbar_seekbar_view"/>
        <TextView android:id="@+id/fragment_black_market_maximum" android:layout_marginEnd="4dp" app:layout_constraintBottom_toBottomOf="@+id/fragment_black_market_seekbar_view" app:layout_constraintEnd_toStartOf="@+id/fragment_black_market_image" app:layout_constraintTop_toTopOf="@+id/fragment_black_market_seekbar_view" style="@style/seekbar_maximum_text_view"/>
        <ImageView android:id="@+id/fragment_black_market_image" android:layout_width="wrap_content" android:layout_height="56dp" android:layout_marginTop="16dp" android:adjustViewBounds="true" android:layout_marginEnd="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toBottomOf="@+id/fragment_black_market_title"/>
        <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:id="@+id/fragment_black_market_description" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/black_market_converting_description" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/fragment_black_market_image" style="@style/shadow_textview"/>
        <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/fragment_black_market_required_tools" android:paddingBottom="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/converting_requirements" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/fragment_black_market_description" style="@style/shadow_textview"/>
        <ListView android:id="@+id/fragment_black_market_list_view" android:layout_height="0dp" app:layout_constraintBottom_toTopOf="@+id/fragment_black_market_bottom_bar" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/fragment_black_market_required_tools" style="@style/fragment_default_list_view"/>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/fragment_black_market_bottom_bar" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0">
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/bottom_bar_background" android:scaleType="fitXY" android:adjustViewBounds="true" app:layout_constraintTop_toTopOf="0"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/top_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.12"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/bottom_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.9"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/left_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.056"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/right_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.945"/>
            <LinearLayout app:layout_constraintBottom_toBottomOf="@+id/bottom_line" app:layout_constraintEnd_toEndOf="@+id/right_line" app:layout_constraintStart_toEndOf="@+id/left_line" app:layout_constraintTop_toBottomOf="@+id/top_line" style="@style/fragment_default_main_bottom_bar_layout">
                <RelativeLayout android:id="@+id/fragment_black_market_back_button" style="@style/bottom_bar_layout">
                    <ImageView android:src="@drawable/button_back" style="@style/bottom_bar_imageview"/>
                    <TextView android:text="@string/button_back" style="@style/bottom_bar_textview"/>
                </RelativeLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
