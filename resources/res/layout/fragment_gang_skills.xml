            <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/fragment_gang_skill_gold_value" android:layout_width="wrap_content" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="@+id/fragment_gang_skill_gold_text" app:layout_constraintEnd_toEndOf="@+id/fragment_gang_skill_respect_value" app:layout_constraintTop_toTopOf="@+id/fragment_gang_skill_gold_text" style="@style/shadow_textview"/>
