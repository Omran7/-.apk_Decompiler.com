            <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:id="@+id/fragment_gang_skill_cash_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/cash_with_two_dotes" app:layout_constraintEnd_toEndOf="@+id/fragment_gang_skill_respect_text" app:layout_constraintTop_toBottomOf="@+id/fragment_gang_skill_respect_text" style="@style/shadow_textview"/>
