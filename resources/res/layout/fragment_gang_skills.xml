        </androidx.constraintlayout.widget.ConstraintLayout>
        <ListView android:id="@+id/fragment_gang_skills_list_view" android:layout_width="match_parent" android:layout_height="0dp" app:layout_constraintBottom_toTopOf="@+id/fragment_gang_skills_bottom_bar" app:layout_constraintTop_toBottomOf="@+id/fragment_gang_skill_details_layout" style="@style/fragment_default_list_view"/>
