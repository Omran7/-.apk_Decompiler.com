<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="40dp" android:layout_marginRight="40dp" android:layout_marginHorizontal="40dp">
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/top_part" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintTop_toTopOf="0">
        <ImageView android:layout_width="match_parent" app:layout_constraintTop_toTopOf="0" style="@style/dialog_top_part_image_view"/>
        <TextView android:id="@+id/dialog_ok_cancel_title" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="@+id/line_top" style="@style/dialog_title_text_view"/>
        <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/line_top" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.28"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ImageView android:id="@+id/middle_part" android:layout_width="match_parent" app:layout_constraintBottom_toTopOf="@+id/bottom_part" app:layout_constraintTop_toBottomOf="@+id/top_part" style="@style/dialog_middle_part_image_view"/>
    <ImageView android:id="@+id/bottom_part" android:layout_width="match_parent" app:layout_constraintTop_toBottomOf="@+id/dialog_sell_item_body_layout" style="@style/dialog_bottom_part_image_view"/>
    <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/line_left" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.035"/>
    <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/line_right" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.965"/>
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/dialog_sell_item_body_layout" android:paddingLeft="8dp" android:paddingRight="8dp" android:layout_width="0dp" android:layout_height="wrap_content" android:paddingHorizontal="8dp" app:layout_constraintEnd_toEndOf="@+id/line_right" app:layout_constraintStart_toEndOf="@+id/line_left" app:layout_constraintTop_toBottomOf="@+id/top_part">
        <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:id="@+id/dialog_ok_cancel_text" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="16dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" style="@style/shadow_textview"/>
        <RelativeLayout android:id="@+id/dialog_ok_cancel_buttons_layout" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/dialog_ok_cancel_text">
            <LinearLayout android:orientation="horizontal" android:id="@+id/dialog_ok_cancel_buttons_confirm_cancel_layout" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content">
                <LinearLayout android:gravity="bottom|right|center_vertical|center_horizontal|center|end" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:paddingStart="0dp" android:paddingEnd="24dp">
                    <RelativeLayout android:gravity="bottom" android:id="@+id/dialog_ok_cancel_confirm_button" android:focusable="true" android:clickable="true" android:layout_width="90dp" android:layout_height="match_parent">
                        <ImageView android:id="@+id/dialog_ok_cancel_confirm_button_image" android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/button_blue" android:adjustViewBounds="true" android:layout_centerInParent="true"/>
                        <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/dialog_ok_cancel_confirm_button_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" style="@style/shadow_textview"/>
                    </RelativeLayout>
                </LinearLayout>
                <LinearLayout android:gravity="bottom|left|center_vertical|center_horizontal|center|start" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:paddingStart="24dp" android:paddingEnd="0dp">
                    <RelativeLayout android:gravity="bottom" android:id="@+id/dialog_ok_cancel_cancel_button" android:focusable="true" android:clickable="true" android:layout_width="90dp" android:layout_height="match_parent">
                        <ImageView android:id="@+id/dialog_ok_cancel_cancel_button_image" android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/button_red" android:adjustViewBounds="true" android:layout_centerInParent="true"/>
                        <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/dialog_ok_cancel_cancel_button_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/button_back" android:layout_centerInParent="true" style="@style/shadow_textview"/>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>
            <RelativeLayout android:id="@+id/dialog_ok_cancel_ok_button" android:focusable="true" android:visibility="gone" android:clickable="true" android:layout_width="90dp" android:layout_height="wrap_content" android:layout_centerHorizontal="true">
                <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/button_blue" android:adjustViewBounds="true" android:layout_centerInParent="true"/>
                <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:id="@+id/dialog_ok_cancel_ok_button_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/button_ok" android:layout_centerInParent="true" style="@style/shadow_textview"/>
            </RelativeLayout>
        </RelativeLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
