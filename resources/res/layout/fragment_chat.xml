<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/background" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:gravity="end" android:orientation="horizontal" android:id="@+id/fragment_chat_top_buttons_layout" android:paddingLeft="16dp" android:paddingTop="8dp" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:weightSum="4" android:layout_alignParentTop="true" android:paddingHorizontal="16dp" app:layout_constraintTop_toTopOf="0">
            <TextView android:layout_gravity="bottom" android:id="@+id/fragment_chat_current_place_button" android:background="@drawable/store_button_disabled" android:visibility="gone" style="@style/tap_top_button"/>
            <TextView android:layout_gravity="bottom" android:id="@+id/fragment_chat_gang_button" android:background="@drawable/store_button_disabled" android:visibility="gone" android:text="@string/gang" style="@style/tap_top_button"/>
            <TextView android:id="@+id/fragment_chat_worldwide_button" android:background="@drawable/store_button_enabled" android:layout_height="36dp" android:text="@string/worldwide" style="@style/tap_top_button"/>
        </LinearLayout>
        <View android:id="@+id/fragment_chat_divider_line" android:background="@color/divider_line" android:layout_width="match_parent" android:layout_height="2dp" app:layout_constraintTop_toBottomOf="@+id/fragment_chat_top_buttons_layout"/>
        <FrameLayout android:id="@+id/fragment_chat_frame_layout" android:layout_width="match_parent" android:layout_height="0dp" app:layout_constraintBottom_toTopOf="@+id/fragment_chat_edit_text_layout" app:layout_constraintTop_toBottomOf="@+id/fragment_chat_divider_line"/>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/fragment_chat_edit_text_layout" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintBottom_toTopOf="@+id/fragment_chat_bottom_bar">
            <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:src="@drawable/chat_edit_text_layout_background" android:adjustViewBounds="true" android:layout_marginEnd="-50dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0"/>
            <ImageView android:id="@+id/fragment_chat_send_button" android:layout_width="wrap_content" android:layout_height="0dp" android:src="@drawable/chat_button" android:adjustViewBounds="true" app:layout_constraintBottom_toBottomOf="@+id/fragment_chat_edit_text" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toEndOf="@+id/fragment_chat_edit_text" app:layout_constraintTop_toTopOf="@+id/fragment_chat_edit_text"/>
            <EditText android:textSize="14sp" android:textStyle="bold" android:textColor="@color/black" android:gravity="right|center_vertical|center_horizontal|center" android:id="@+id/fragment_chat_edit_text" android:background="@null" android:paddingLeft="8dp" android:paddingTop="2dp" android:paddingRight="8dp" android:paddingBottom="2dp" android:layout_width="0dp" android:layout_height="0dp" android:hint="@string/hint_type_here" android:paddingHorizontal="8dp" android:paddingVertical="2dp" app:layout_constraintBottom_toTopOf="@+id/space_bottom" app:layout_constraintEnd_toStartOf="@+id/space_end" app:layout_constraintStart_toEndOf="@+id/space_start" app:layout_constraintTop_toBottomOf="@+id/space_top" style="@style/shadow_textview_small"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/space_top" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.16"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/space_bottom" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.83"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/space_start" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.056"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/space_end" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.78"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/fragment_chat_bottom_bar" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0">
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/bottom_bar_background" android:scaleType="fitXY" android:adjustViewBounds="true" app:layout_constraintTop_toTopOf="0"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/top_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.12"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/bottom_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.9"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/left_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.056"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/right_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.945"/>
            <LinearLayout app:layout_constraintBottom_toBottomOf="@+id/bottom_line" app:layout_constraintEnd_toEndOf="@+id/right_line" app:layout_constraintStart_toEndOf="@+id/left_line" app:layout_constraintTop_toBottomOf="@+id/top_line" style="@style/fragment_default_main_bottom_bar_layout">
                <RelativeLayout android:id="@+id/fragment_chat_back_button" style="@style/bottom_bar_layout">
                    <ImageView android:src="@drawable/button_back" style="@style/bottom_bar_imageview"/>
                    <TextView android:text="@string/button_back" style="@style/bottom_bar_textview"/>
                </RelativeLayout>
                <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="4">
                    <LinearLayout android:orientation="horizontal" android:id="@+id/fragment_chat_speakers_layout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="2dp">
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:id="@+id/fragment_chat_speakers_number" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="4dp" style="@style/shadow_textview"/>
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/chat_speakers" style="@style/shadow_textview"/>
                    </LinearLayout>
                    <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/fragment_chat_time_and_date" android:layout_width="wrap_content" android:layout_height="wrap_content" style="@style/shadow_textview"/>
                </LinearLayout>
                <RelativeLayout android:id="@+id/fragment_chat_help_button" style="@style/bottom_bar_layout">
                    <ImageView android:src="@drawable/button_help" style="@style/bottom_bar_imageview"/>
                    <TextView android:text="@string/button_help" style="@style/bottom_bar_textview"/>
                </RelativeLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
