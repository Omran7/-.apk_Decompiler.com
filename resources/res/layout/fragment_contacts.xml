<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:background="@color/background" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:gravity="center_horizontal" android:orientation="horizontal" android:id="@+id/fragment_contacts_top_buttons_layout" android:paddingLeft="16dp" android:paddingTop="8dp" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:weightSum="4" android:layout_alignParentTop="true" android:paddingHorizontal="16dp" app:layout_constraintTop_toTopOf="0">
            <TextView android:layout_gravity="bottom" android:id="@+id/fragment_contacts_blocking_button" android:background="@drawable/store_button_disabled" android:text="@string/blocking" style="@style/tap_top_button"/>
            <TextView android:layout_gravity="bottom" android:id="@+id/fragment_contacts_friends_button" android:background="@drawable/store_button_disabled" android:text="@string/friends" style="@style/tap_top_button"/>
            <TextView android:id="@+id/fragment_contacts_requests_button" android:background="@drawable/store_button_enabled" android:layout_height="36dp" android:text="@string/requests" style="@style/tap_top_button"/>
        </LinearLayout>
        <View android:id="@+id/fragment_contacts_divider_line" android:background="@color/divider_line" android:layout_width="match_parent" android:layout_height="2dp" app:layout_constraintTop_toBottomOf="@+id/fragment_contacts_top_buttons_layout"/>
        <FrameLayout android:id="@+id/fragment_contacts_frame_layout" android:layout_width="match_parent" android:layout_height="0dp" app:layout_constraintBottom_toTopOf="@+id/fragment_contacts_bottom_bar" app:layout_constraintTop_toBottomOf="@+id/fragment_contacts_divider_line"/>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/fragment_contacts_bottom_bar" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0">
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/bottom_bar_background" android:scaleType="fitXY" android:adjustViewBounds="true" app:layout_constraintTop_toTopOf="0"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/top_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.12"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/bottom_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.9"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/left_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.056"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/right_line" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.945"/>
            <LinearLayout app:layout_constraintBottom_toBottomOf="@+id/bottom_line" app:layout_constraintEnd_toEndOf="@+id/right_line" app:layout_constraintStart_toEndOf="@+id/left_line" app:layout_constraintTop_toBottomOf="@+id/top_line" style="@style/fragment_default_main_bottom_bar_layout">
                <RelativeLayout android:id="@+id/fragment_contacts_back_button" style="@style/bottom_bar_layout">
                    <ImageView android:src="@drawable/button_back" style="@style/bottom_bar_imageview"/>
                    <TextView android:text="@string/button_back" style="@style/bottom_bar_textview"/>
                </RelativeLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
