<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:gravity="center" android:layout_gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="20dp">
    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout android:gravity="end" android:orientation="vertical" android:background="@drawable/toast_background" android:padding="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true">
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/toast_material_details_name" android:layout_width="wrap_content" android:layout_height="wrap_content" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0" style="@style/shadow_textview"/>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/toast_material_details_name">
                <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp">
                    <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/toast_material_details_description" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:layout_marginEnd="8dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" style="@style/shadow_textview"/>
                    <LinearLayout android:gravity="end" android:orientation="vertical" android:id="@+id/toast_material_details_special_equipment_properties" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0">
                        <LinearLayout android:orientation="horizontal" android:id="@+id/toast_material_details_special_equipment_skills_layout" android:paddingBottom="4dp" android:layout_width="wrap_content" android:layout_height="28dp"/>
                        <LinearLayout android:gravity="right|center_vertical|center_horizontal|center|end" android:orientation="horizontal" android:paddingTop="2dp" android:paddingBottom="2dp" android:layout_width="wrap_content" android:layout_height="28dp" android:paddingVertical="2dp">
                            <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/toast_material_details_happiness" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="1dp" android:layout_marginEnd="4dp" style="@style/shadow_textview_small"/>
                            <ImageView android:layout_width="wrap_content" android:layout_height="24dp" android:src="@drawable/happiness_icon" android:adjustViewBounds="true"/>
                        </LinearLayout>
                    </LinearLayout>
                    <RelativeLayout android:orientation="horizontal" android:id="@+id/toast_material_details_package_content" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0">
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/toast_material_details_package_content_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:lineSpacingExtra="-3.5dp" android:layout_toEndOf="@+id/toast_material_details_package_content_count" style="@style/shadow_textview"/>
                        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/toast_material_details_package_content_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="12dp" android:layout_alignParentStart="true" style="@style/shadow_textview"/>
                    </RelativeLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/toast_material_details_image_layout" android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <ImageView android:id="@+id/toast_material_details_image" android:layout_width="wrap_content" android:layout_height="56dp" android:adjustViewBounds="true" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintHorizontal_bias="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" app:layout_constraintVertical_bias="0"/>
                    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/toast_material_details_level_layout" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0">
                        <ImageView android:layout_width="0dp" android:layout_height="36dp" android:src="@drawable/upgrading_sign" android:adjustViewBounds="true" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0"/>
                        <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:id="@+id/toast_material_details_level" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintHeight_percent="0.65" app:layout_constraintTop_toTopOf="0" app:layout_constraintWidth_percent="0.7"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </RelativeLayout>
</RelativeLayout>
