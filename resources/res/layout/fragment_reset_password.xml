<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/three_form_four" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.7"/>
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="32dp" android:layout_marginRight="32dp" android:layout_marginHorizontal="32dp" app:layout_constraintBottom_toBottomOf="@+id/three_form_four">
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/top_part" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintTop_toTopOf="0">
            <ImageView android:layout_width="match_parent" app:layout_constraintTop_toTopOf="0" style="@style/dialog_top_part_image_view"/>
            <ImageView android:id="@+id/fragment_reset_password_close_button" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintStart_toEndOf="@+id/line_left2" app:layout_constraintTop_toTopOf="@+id/line_top" style="@style/dialog_x_button_image_view"/>
            <TextView android:text="@string/reset_password_title" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="@+id/line_top" style="@style/dialog_title_text_view"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/line_top" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.28"/>
            <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/line_left2" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.035"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <ImageView android:id="@+id/middle_part" android:layout_width="match_parent" app:layout_constraintBottom_toTopOf="@+id/bottom_part" app:layout_constraintTop_toBottomOf="@+id/top_part" style="@style/dialog_middle_part_image_view"/>
        <ImageView android:id="@+id/bottom_part" android:layout_width="match_parent" app:layout_constraintTop_toBottomOf="@+id/fragment_reset_password_body_layout" style="@style/dialog_bottom_part_image_view"/>
        <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/line_left" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.035"/>
        <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/line_right" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.965"/>
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/fragment_reset_password_body_layout" android:paddingLeft="8dp" android:paddingRight="8dp" android:layout_width="0dp" android:layout_height="wrap_content" android:paddingHorizontal="8dp" app:layout_constraintEnd_toEndOf="@+id/line_right" app:layout_constraintStart_toEndOf="@+id/line_left" app:layout_constraintTop_toBottomOf="@+id/top_part">
            <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/fragment_reset_password_fields_layout" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0">
                <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/fragment_reset_password_field_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/enter_user_name_or_email_remembered" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" style="@style/shadow_textview"/>
                <EditText android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:textColorHint="@color/edit_text_hint" android:gravity="left|center_vertical|center_horizontal|center" android:id="@+id/fragment_reset_password_email_field" android:background="@drawable/input_field" android:paddingLeft="6dp" android:paddingRight="6dp" android:focusable="true" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="@string/hint_user_name_or_email" android:maxLines="1" android:inputType="textEmailAddress" android:paddingHorizontal="6dp" app:layout_constraintEnd_toEndOf="@+id/fragment_reset_password_field_title" app:layout_constraintStart_toStartOf="@+id/fragment_reset_password_field_title" app:layout_constraintTop_toBottomOf="@+id/fragment_reset_password_field_title" style="@style/shadow_textview_small"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_gray_white" android:id="@+id/fragment_reset_password_description" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/reset_password_description" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/fragment_reset_password_fields_layout" style="@style/shadow_textview"/>
            <RelativeLayout android:id="@+id/fragment_reset_password_send_button" android:focusable="true" android:clickable="true" android:layout_width="90dp" android:layout_height="match_parent" android:layout_marginTop="16dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/fragment_reset_password_description">
                <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/button_blue" android:adjustViewBounds="true" android:layout_centerInParent="true"/>
                <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/button_send" android:layout_centerInParent="true" style="@style/shadow_textview"/>
            </RelativeLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout android:gravity="center" android:id="@+id/fragment_reset_password_progress_bar" android:background="@color/progress_bar_background" android:focusable="true" android:visibility="gone" android:clickable="true" android:layout_width="match_parent" android:layout_height="match_parent">
        <ProgressBar android:layout_width="70dp" android:layout_height="70dp" android:indeterminate="true" android:indeterminateDrawable="@drawable/progress_bar_bullet"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
