<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="40dp" android:layout_marginRight="40dp" android:layout_marginHorizontal="40dp">
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/top_part" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintTop_toTopOf="0">
        <ImageView android:layout_width="match_parent" app:layout_constraintTop_toTopOf="0" style="@style/dialog_top_part_image_view"/>
        <ImageView android:id="@+id/dialog_gang_position_close_button" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintStart_toEndOf="@+id/line_left2" app:layout_constraintTop_toTopOf="@+id/line_top" style="@style/dialog_x_button_image_view"/>
        <TextView android:text="@string/change_gang_position_title" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="@+id/line_top" style="@style/dialog_title_text_view"/>
        <androidx.constraintlayout.widget.Guideline android:orientation="horizontal" android:id="@+id/line_top" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.28"/>
        <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/line_left2" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.035"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ImageView android:id="@+id/middle_part" android:layout_width="match_parent" app:layout_constraintBottom_toTopOf="@+id/bottom_part" app:layout_constraintTop_toBottomOf="@+id/top_part" style="@style/dialog_middle_part_image_view"/>
    <ImageView android:id="@+id/bottom_part" android:layout_width="match_parent" app:layout_constraintTop_toBottomOf="@+id/fragment_gang_position_body_layout" style="@style/dialog_bottom_part_image_view"/>
    <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/line_left" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.035"/>
    <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/line_right" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintGuide_percent="0.965"/>
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/fragment_gang_position_body_layout" android:paddingLeft="8dp" android:paddingRight="8dp" android:layout_width="0dp" android:layout_height="wrap_content" android:paddingHorizontal="8dp" app:layout_constraintEnd_toEndOf="@+id/line_right" app:layout_constraintStart_toEndOf="@+id/line_left" app:layout_constraintTop_toBottomOf="@+id/top_part">
        <RadioGroup android:gravity="end" android:orientation="vertical" android:id="@+id/dialog_gang_position_radio_group" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0">
            <RadioButton android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/dialog_gang_position_vise_radio_button" android:tag="vise" android:layout_width="match_parent" android:layout_height="wrap_content" android:button="@drawable/custom_check_box"/>
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:src="@drawable/line_divider" android:adjustViewBounds="true" app:layout_constraintTop_toBottomOf="@+id/dialog_gang_position_radio_group"/>
            <RadioButton android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/dialog_gang_position_advisor_radio_button" android:tag="advisor" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:button="@drawable/custom_check_box"/>
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:src="@drawable/line_divider" android:adjustViewBounds="true" app:layout_constraintTop_toBottomOf="@+id/dialog_gang_position_radio_group"/>
            <RadioButton android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/dialog_gang_position_operation_chief_radio_button" android:tag="operation_chief" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:button="@drawable/custom_check_box"/>
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:src="@drawable/line_divider" android:adjustViewBounds="true" app:layout_constraintTop_toBottomOf="@+id/dialog_gang_position_radio_group"/>
            <RadioButton android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/dialog_gang_position_fighter_radio_button" android:tag="fighter" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:button="@drawable/custom_check_box"/>
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:src="@drawable/line_divider" android:adjustViewBounds="true" app:layout_constraintTop_toBottomOf="@+id/dialog_gang_position_radio_group"/>
            <RadioButton android:textSize="12sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/dialog_gang_position_new_radio_button" android:tag="new" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:button="@drawable/custom_check_box"/>
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:src="@drawable/line_divider" android:adjustViewBounds="true" app:layout_constraintTop_toBottomOf="@+id/dialog_gang_position_radio_group"/>
        </RadioGroup>
        <RelativeLayout android:id="@+id/dialog_gang_position_change_button" android:focusable="true" android:clickable="true" android:layout_width="90dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/dialog_gang_position_radio_group">
            <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/button_blue" android:adjustViewBounds="true" android:layout_centerInParent="true"/>
            <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/button_change" android:layout_centerInParent="true" style="@style/shadow_textview"/>
        </RelativeLayout>
